# Base URL of the deployed backend API (set this in Vercel's project settings for production).
# Leave unset locally — the dev server proxies /api to http://localhost:8000 instead.
VITE_API_URL=https://your-backend-url.up.railway.app

# Google OAuth client ID (public) for "Sign in with Google". Same client ID as the backend.
# Without it, the Google button shows disabled. Add to Vercel env vars for production.
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
