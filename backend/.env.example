DATABASE_URL=postgresql://ojas:ojas_dev_password@localhost:5432/ojas
SECRET_KEY=replace-with-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=60

GROQ_API_KEY=replace-with-your-groq-api-key
CHROMA_HOST=localhost
CHROMA_PORT=8001

# Comma-separated frontend origins allowed to call the API (add your Vercel URL in production)
CORS_ORIGINS=http://localhost:5173

# YouTube Data API (Discover) — leave blank to use stub video cards
YOUTUBE_API_KEY=

# AWS S3 (PDF export) — leave blank to download the PDF directly instead of uploading
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
S3_BUCKET=

# Google Calendar OAuth — leave blank to disable the integration
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/integrations/google/callback
